{
  "name": "polyvault-contracts",
  "version": "1.0.0",
  "description": "PolyVault - USDC vault for Polymarket AI prediction trading",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:coverage": "hardhat coverage",
    "deploy:local": "hardhat run scripts/deploy-vault.ts --network localhost",

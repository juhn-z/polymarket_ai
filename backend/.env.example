# ---------------- Required for demo ----------------
# (Hardhat localhost defaults work without further setup once the chain is up)
DATABASE_URL=sqlite+aiosqlite:///./polypredict.db
ADMIN_API_KEY=dev_admin_key
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Polygon RPC + addresses — overwritten by `pnpm dev:contracts` script
POLYGON_RPC_URL=http://127.0.0.1:8545
# WARNING: this is Hardhat account #0 from the public default mnemonic — NEVER use on mainnet/Polygon.
ADMIN_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
VAULT_CONTRACT_ADDRESS=
USDC_CONTRACT_ADDRESS=

# ---------------- API keys (only OpenAI + Polymarket are required) ----------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
# OpenAI-compatible base URL. For the AIHubMix proxy use:
#   OPENAI_BASE_URL=https://aihubmix.com/v1   (and set OPENAI_MODEL=gpt-5.5)
OPENAI_BASE_URL=https://api.openai.com/v1

# Trade gate (PRD §3.4 default 0.25). The blind/decisive AI prompt typically
# produces 5-15% honest edges on Polymarket BTC events. Override only for
# local demo (e.g. MIN_EDGE=0.10); production must keep 0.25.
MIN_EDGE=0.25

POLYMARKET_GAMMA_API_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_API_URL=https://clob.polymarket.com
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_PASSPHRASE=

# ---------------- Optional (graceful no-op when blank) ----------------
# Binance + Fear&Greed are public APIs; no key needed.
# CryptoPanic free-tier requires a key; if blank, news is omitted from the bundle.
BINANCE_API_URL=https://api.binance.com
FEAR_GREED_API_URL=https://api.alternative.me/fng/
CRYPTOPANIC_API_URL=https://cryptopanic.com/api/v1/
CRYPTOPANIC_API_KEY=

LOG_LEVEL=INFO
